;
; BIND data file for local loopback interface
;
$TTL    604800
@       IN      SOA     ukk-alfa.net. root.ukk-alfa.net. (
                              2         ; Serial
                         604800         ; Refresh
                          86400         ; Retry
                        2419200         ; Expire
                         604800 )       ; Negative Cache TTL
;
@       IN      NS      ukk-alfa.net.
@       IN      A       192.168.100.2
www     IN      A       192.168.100.2
